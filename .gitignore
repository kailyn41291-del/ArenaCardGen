# ── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# ── 虛擬環境 ──────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── IDE / 編輯器 ──────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# ── 系統垃圾檔 ────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ── 環境變數 / 密鑰 ───────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key

# ── 本地暫存 / scratch ───────────────────────────────────
scratch_*.py
_pdf_pages/
*.local.json
last_session.json

# ── Logs ──────────────────────────────────────────────────
*.log
logs/

# ── 字卡輸出(避免不小心 commit 匯出的 PNG)──────────────
output/
exports/
*.png
!.claude/**/*.png
!assets/**/*.png

# ── Resolume 相關(將來如果加 .avc / clip 設定) ────────
*.avc

# ── Electron / Node ──────────────────────────────────────
node_modules/
out/
.electron-cache/
# Electron build 產物 (electron-builder 輸出在 app/dist/)
app/dist/

# ── Web bundle build artifacts(esbuild + Tailwind + pdf worker)─────
# CI 跟本地 build 時 generate,不 commit(讓每次 build 都新鮮)
app/web/dist/

# ── Claude Code 內部設定 / state(不公開)──────────────
.claude/
